# Terraform state files
*.tfstate
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform variable files (contain secrets/env-specific values)
# Keep *.tfvars.example committed as templates
*.tfvars
!*.tfvars.example

# Backend config (contains S3 bucket / DynamoDB table names)
backend.tfvars

# Lambda zip artifacts (generated by archive provider into .build/)
.build/

# OS files
.DS_Store
Thumbs.db

# Claude Code session data
.claude/
